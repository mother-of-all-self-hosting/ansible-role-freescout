TZ={{ freescout_environment_variables_tz }}

TIMEZONE={{ freescout_environment_variables_tz }}

# See: https://github.com/tiredofit/docker-freescout/issues/202
#      https://github.com/tiredofit/docker-alpine/blob/main/README.md#permissions
CONTAINER_USER_NGINX={{ freescout_uid }}

CONTAINER_LOG_LEVEL={{ freescout_environment_variables_container_log_level }}

ADMIN_EMAIL={{ freescout_environment_variables_admin_email }}
ADMIN_PASS={{ freescout_environment_variables_admin_password }}

APPLICATION_NAME={{ freescout_environment_variables_application_name }}
SITE_URL={{ freescout_scheme }}://{{ freescout_hostname }}
DISPLAY_ERRORS={{ freescout_environment_variables_display_errors }}
ENABLE_AUTO_UPDATE={{ freescout_environment_variables_enable_auto_update }}

{% if freescout_database_type == 'mysql' %}
DB_TYPE=mysql
DB_HOST={{ freescout_database_mysql_hostname }}
DB_PORT={{ freescout_database_mysql_port }}
DB_USER={{ freescout_database_mysql_username }}
DB_PASS={{ freescout_database_mysql_password }}
DB_SSL={{ freescout_database_mysql_sslmode }}
{% endif %}
{% if freescout_database_type == 'postgres' %}
DB_TYPE=pgsql
DB_HOST={{ freescout_database_postgres_hostname }}
DB_PORT={{ freescout_database_postgres_port }}
DB_USER={{ freescout_database_postgres_username }}
DB_PASS={{ freescout_database_postgres_password }}
DB_PGSQL_SSL_MODE={{ freescout_database_postgres_sslmode }}
{% endif %}
DB_NAME={{ freescout_database_name }}

{{ freescout_environment_variables_additional_variables }}
